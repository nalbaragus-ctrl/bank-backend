FROM php:8.4-fpm-alpine

# Install Nginx, Supervisor, dan driver PostgreSQL
RUN apk add --no-cache nginx supervisor curl libpq-dev \
    && docker-php-ext-install pdo pdo_pgsql

# Setel folder kerja
WORKDIR /var/www/html
COPY . .

# Install Composer secara aman
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer
RUN composer install --no-dev --optimize-autoloader --no-scripts

# Salin konfigurasi server internal bawaan Laravel untuk produksi
RUN cp .env.example .env && php artisan package:discover

# Atur izin folder agar tidak Error 500
RUN chown -R www-data:www-data /var/www/html/storage /var/www/html/bootstrap/cache

# Jalankan server internal PHP di port yang diminta Railway
EXPOSE 8080
CMD php artisan optimize:clear && php artisan serve --host=0.0.0.0 --port=${PORT:-8080}
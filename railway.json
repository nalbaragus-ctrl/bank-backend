{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "php84",
            "php84Packages.composer",
            "php84Packages.pdo_pgsql"
          ]
        }
      }
    }
  },
  "deploy": {
    "start": {
      "cmd": "php artisan optimize:clear && php artisan serve --host=0.0.0.0 --port=$PORT"
    }
  }
}